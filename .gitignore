# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs/

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env*.example
!.env.sample
!.env*.sample
.envrc
.direnv/
*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# deployment / build caches
dist/
tmp/
temp/
.cache/
.eslintcache
.stylelintcache

# package manager caches
.npm/
.pnpm-store/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS files
Thumbs.db
Desktop.ini

# common secret/key artifacts
*.key
*.pfx
*.p12
*.crt
*.cer
*.der
*.jks
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*service-account*.json
